@page
@model MRMstudios.Pages.PackagesModel
@{
    ViewData["Title"] = "Photography Packages";
}

<section class="page-hero" style="background-image: linear-gradient(135deg, rgba(24, 35, 31, 0.88) 0%, rgba(40, 92, 78, 0.68) 40%, rgba(185, 78, 53, 0.75) 100%), url('@(Model.BackgroundImageUrl ?? "/images/wedding.jpg")'); background-size: cover; background-position: center;">
    <div class="container">
        <h1>Photography Packages</h1>
        <p>Simple starting points for portraits, weddings, events, and business photography.</p>
    </div>
</section>

<div class="container page-section">
    <div class="section-heading">
        <div class="eyebrow">Services</div>
        <h2>Choose your session</h2>
        <p class="section-kicker">Each package includes planning, edited high-resolution images, and digital delivery.</p>
    </div>

    <div class="row g-4">
        @foreach (var service in Model.Services)
        {
            <div class="col-md-6 col-lg-3">
                <div class="card package-card h-100">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@service.Name</h5>
                        <p class="card-text text-muted flex-grow-1">@service.Description</p>
                        <div class="price-section">
                            <span class="package-price">$@service.Price</span>
                        </div>
                    </div>
                    <div class="card-footer">
                        <a asp-page="/Booking" class="btn btn-primary btn-sm w-100">Book This Package</a>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="row mt-5">
        <div class="col-md-12">
            <div class="info-box">
                <h4>What's Included?</h4>
                <ul>
                    <li>Professional photography session</li>
                    <li>High-resolution edited photos</li>
                    <li>Digital copies in cloud storage</li>
                    <li>Consultation before the session</li>
                </ul>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-12">
            <div class="contact-cta">
                <h5>Need a custom package?</h5>
                <p class="mb-0">Don't see what you're looking for? <a href="/Contact">Contact us</a> to discuss a custom package tailored to your needs.</p>
            </div>
        </div>
    </div>
</div>
