@page
@model MRMstudios.Pages.ContactModel
@{
    ViewData["Title"] = "Contact Us";
}

<section class="page-hero">
    <div class="container">
        <h1>Contact MRMstudios</h1>
        <p>Ask about availability, packages, or a custom photography session.</p>
    </div>
</section>

<div class="container page-section">
    <div class="row justify-content-center g-5">
        <div class="col-lg-7">
            @if (!string.IsNullOrEmpty(Model.ConfirmationMessage))
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @Model.ConfirmationMessage
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @Model.ErrorMessage
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <form method="post" class="contact-form">
                <div class="mb-3">
                    <label for="name" class="form-label">Your Name *</label>
                    <input type="text" class="form-control" id="name" asp-for="Name" required>
                </div>

                <div class="mb-3">
                    <label for="email" class="form-label">Email Address *</label>
                    <input type="email" class="form-control" id="email" asp-for="Email" required>
                </div>

                <div class="mb-3">
                    <label for="subject" class="form-label">Subject *</label>
                    <input type="text" class="form-control" id="subject" asp-for="Subject" placeholder="Wedding package inquiry" required>
                </div>

                <div class="mb-4">
                    <label for="message" class="form-label">Message *</label>
                    <textarea class="form-control" id="message" asp-for="Message" rows="6" placeholder="Tell us about your date, location, and session goals." required></textarea>
                </div>

                <button type="submit" class="btn btn-primary w-100">Send Message</button>
            </form>
        </div>

        <div class="col-lg-5">
            <div class="section-heading text-start mb-4">
                <div class="eyebrow">Details</div>
                <h2>Plan the next step.</h2>
                <p>Send a message with your preferred date and service type. We will reply with availability and booking details.</p>
            </div>

            <div class="row g-3">
                <div class="col-md-6 col-lg-12">
                    <div class="contact-info">
                        <h5>Email</h5>
                        <p class="mb-0"><a href="mailto:mel.dimplz@gmail.com">mel.dimplz@gmail.com</a></p>
                    </div>
                </div>
                <div class="col-md-6 col-lg-12">
                    <div class="contact-info">
                        <h5>Phone</h5>
                        <p class="mb-0"><a href="tel:+46708417437">+46 70 841 7437</a></p>
                    </div>
                </div>
                <div class="col-md-6 col-lg-12">
                    <div class="contact-info">
                        <h5>Location</h5>
                        <p class="mb-0">Gweru, Zimbabwe</p>
                    </div>
                </div>
                <div class="col-md-6 col-lg-12">
                    <div class="payment-info">
                        <h5>Booking Deposit</h5>
                        <p>A 50% deposit confirms your booking. The remaining balance is due 7 days before your session.</p>
                        <p class="mb-0"><strong>Payment methods:</strong> Cash, Ecocash, bank transfer.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
