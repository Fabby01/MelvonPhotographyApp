@page
@model MRMstudios.Pages.AdminBookingsModel
@{
    ViewData["Title"] = "Admin Dashboard - Manage Bookings";
    var showConfirmPopup = TempData["ShowConfirmPopup"]?.ToString() == "true";
    var popupName = TempData["ConfirmClientName"]?.ToString() ?? "Customer";
    var popupEmail = TempData["ConfirmClientEmail"]?.ToString() ?? string.Empty;
    var popupPhone = TempData["ConfirmClientPhone"]?.ToString() ?? string.Empty;
    var popupService = TempData["ConfirmService"]?.ToString() ?? "Photography Session";
    var popupDate = TempData["ConfirmDate"]?.ToString() ?? string.Empty;
    var popupAction = TempData["PopupAction"]?.ToString() ?? "Confirmed";
    var isCancelledAction = popupAction == "Cancelled";
    var whatsappPhone = new string(popupPhone.Where(char.IsDigit).ToArray());
    var whatsappMessage = Uri.EscapeDataString(
        isCancelledAction
            ? $"Hi {popupName}, your {popupService} booking for {popupDate} has been cancelled. Please reply if you want to reschedule."
            : $"Hi {popupName}, your {popupService} booking for {popupDate} has been confirmed. Please reply so we can finalize your session details.");
    var whatsappUrl = string.IsNullOrWhiteSpace(whatsappPhone)
        ? string.Empty
        : $"https://wa.me/{whatsappPhone}?text={whatsappMessage}";
}

<section class="admin-header">
    <div class="container">
        <div class="admin-header-content">
            <div>
                <h1>Booking Management</h1>
                <p>Manage customer bookings and session scheduling.</p>
            </div>
            <div class="admin-actions">
                <a href="/AdminGallery" class="btn btn-outline-primary">Manage Media</a>
                <form method="post" asp-page-handler="Logout" class="logout-form">
                    <button type="submit" class="btn btn-danger">Sign Out</button>
                </form>
            </div>
        </div>
    </div>
</section>

<div class="container mb-5">
    <div class="admin-stats">
        <div class="stat-card">
            <div class="stat-number">@Model.Bookings.Count</div>
            <div class="stat-label">Total Bookings</div>
        </div>
        <div class="stat-card pending">
            <div class="stat-number">@Model.Bookings.Count(b => b.Status == "Pending")</div>
            <div class="stat-label">Pending</div>
        </div>
        <div class="stat-card confirmed">
            <div class="stat-number">@Model.Bookings.Count(b => b.Status == "Confirmed")</div>
            <div class="stat-label">Confirmed</div>
        </div>
        <div class="stat-card cancelled">
            <div class="stat-number">@Model.Bookings.Count(b => b.Status == "Cancelled")</div>
            <div class="stat-label">Cancelled</div>
        </div>
    </div>

    @if (!Model.Bookings.Any())
    {
        <div class="alert alert-info">
            <strong>No bookings yet.</strong> When clients submit booking requests, they will appear here.
        </div>
    }
    else
    {
        <div class="bookings-table-wrapper">
            <table class="bookings-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Client Name</th>
                        <th>Contact</th>
                        <th>Service</th>
                        <th>Session Date</th>
                        <th>Status</th>
                        <th>Booked On</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var booking in Model.Bookings)
                    {
                        <tr class="booking-row @booking.Status.ToLower()">
                            <td data-label="ID"><span class="booking-id">#@booking.Id</span></td>
                            <td data-label="Client Name">@booking.FullName</td>
                            <td data-label="Contact">
                                <div class="contact-info">
                                    <a href="mailto:@booking.Email" title="Email">@booking.Email</a><br/>
                                    <a href="tel:@booking.PhoneNumber" title="Call">@booking.PhoneNumber</a>
                                </div>
                            </td>
                            <td data-label="Service">
                                <span class="service-badge">@booking.ServiceType</span>
                            </td>
                            <td data-label="Session Date">
                                <strong>@booking.PreferredDate.ToString("MMM dd, yyyy")</strong>
                            </td>
                            <td data-label="Status">
                                @if (booking.Status == "Pending")
                                {
                                    <span class="status-badge pending">Pending</span>
                                }
                                else if (booking.Status == "Confirmed")
                                {
                                    <span class="status-badge confirmed">Confirmed</span>
                                }
                                else
                                {
                                    <span class="status-badge cancelled">Cancelled</span>
                                }
                            </td>
                            <td data-label="Booked On">@booking.BookingDate.ToString("MMM dd, yyyy")</td>
                            <td data-label="Actions">
                                <div class="action-buttons">
                                    @if (booking.Status == "Pending")
                                    {
                                        <form method="post" style="display: inline;">
                                            <button type="submit" asp-page-handler="Confirm" asp-route-id="@booking.Id" class="btn btn-sm btn-success" title="Confirm booking">Confirm</button>
                                        </form>
                                    }
                                    @if (booking.Status != "Cancelled")
                                    {
                                        <form method="post" style="display: inline;">
                                            <button type="submit" asp-page-handler="Cancel" asp-route-id="@booking.Id" class="btn btn-sm btn-warning" title="Cancel booking">Cancel</button>
                                        </form>
                                    }
                                    <form method="post" style="display: inline;">
                                        <button type="submit" asp-page-handler="Delete" asp-route-id="@booking.Id" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure you want to delete this booking?')" title="Delete permanently">Delete</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        @if (!string.IsNullOrEmpty(booking.SpecialNotes))
                        {
                            <tr class="notes-row">
                                <td colspan="8">
                                    <div class="special-notes">
                                        <strong>Special Requests:</strong><br/>
                                        @booking.SpecialNotes
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@if (showConfirmPopup)
{
    <div class="modal fade" id="confirmContactModal" tabindex="-1" aria-labelledby="confirmContactModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="confirmContactModalLabel">Booking @popupAction</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p><strong>@popupName</strong> has been marked as @popupAction.ToLowerInvariant().</p>
                    @if (isCancelledAction)
                    {
                        <p>Please contact the customer now to inform them the booking is cancelled and discuss rescheduling.</p>
                    }
                    else
                    {
                        <p>Please contact the customer now to finalize details and inform them the booking is confirmed.</p>
                    }
                    <div class="contact-cta">
                        <div><strong>Service:</strong> @popupService</div>
                        <div><strong>Date:</strong> @popupDate</div>
                        <div><strong>Email:</strong> @popupEmail</div>
                        <div><strong>Phone:</strong> @popupPhone</div>
                    </div>
                </div>
                <div class="modal-footer" style="display:flex; gap:0.5rem; flex-wrap:wrap;">
                    @if (!string.IsNullOrWhiteSpace(popupEmail))
                    {
                        <a class="btn btn-primary" href="mailto:@popupEmail?subject=Your%20booking%20is%20@popupAction.ToLowerInvariant()">Email Customer</a>
                    }
                    @if (!string.IsNullOrWhiteSpace(popupPhone))
                    {
                        <a class="btn btn-success" href="tel:@popupPhone">Call Customer</a>
                    }
                    @if (!string.IsNullOrWhiteSpace(whatsappUrl))
                    {
                        <a class="btn btn-outline-success" href="@whatsappUrl" target="_blank" rel="noopener noreferrer">WhatsApp</a>
                    }
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Done</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var modalElement = document.getElementById('confirmContactModal');
            if (!modalElement || typeof bootstrap === 'undefined') return;
            var modal = new bootstrap.Modal(modalElement);
            modal.show();
        });
    </script>
}
