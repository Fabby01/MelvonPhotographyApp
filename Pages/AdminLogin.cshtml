@page
@model AdminLoginModel
@{
    ViewData["Title"] = "Admin Login";
}

<div class="login-container">
    <div class="login-card">
        <div class="login-header">
            <h1>Admin Access</h1>
            <p>Enter your credentials to continue</p>
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger" role="alert">
                <strong>Login Failed</strong><br/>
                @TempData["Error"]
            </div>
        }

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success" role="alert">
                @TempData["Success"]
            </div>
        }

        <form method="post" class="login-form">
            <div class="form-group">
                <label for="username" class="form-label">Username</label>
                <input type="text" 
                       id="username" 
                       name="Username" 
                       class="form-control" 
                       placeholder="Enter admin username"
                       required
                       autocomplete="username">
            </div>

            <div class="form-group">
                <label for="password" class="form-label">Password</label>
                <input type="password" 
                       id="password" 
                       name="Password" 
                       class="form-control" 
                       placeholder="Enter admin password"
                       required
                       autocomplete="current-password">
            </div>

            <button type="submit" class="btn btn-primary w-100">
                <span>Sign In</span>
            </button>
        </form>

        <form method="post" asp-page-handler="GeneratePassword" style="margin-top: 1rem;">
            <button type="submit" class="btn btn-outline-secondary w-100">
                Generate New Password and Email It
            </button>
            <p style="margin-top: 0.75rem; margin-bottom: 0; font-size: 0.85rem; color: var(--text-secondary);">
                Sends the new password to <strong>fabiana.mkova2001@gmail.com</strong>.
            </p>
        </form>

        <div class="login-footer">
            <p>Return to <a href="/">home page</a></p>
        </div>
    </div>
</div>

<style>
.login-container {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: calc(100vh - 120px);
    background: linear-gradient(135deg, #f8fafc 0%, rgba(99, 102, 241, 0.05) 100%);
    padding: 2rem;
}

.login-card {
    background: white;
    border-radius: 16px;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
    width: 100%;
    max-width: 400px;
    padding: 3rem 2rem;
    border: 1px solid #e2e8f0;
}

.login-header {
    text-align: center;
    margin-bottom: 2rem;
}

.login-header h1 {
    font-size: 1.8rem;
    margin-bottom: 0.5rem;
    color: var(--dark-text);
}

.login-header p {
    color: var(--text-secondary);
    font-size: 0.95rem;
}

.login-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
}

.form-group {
    display: flex;
    flex-direction: column;
}

.form-group .form-label {
    font-weight: 600;
    margin-bottom: 0.75rem;
}

.login-footer {
    text-align: center;
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid #e2e8f0;
}

.login-footer p {
    margin: 0;
    font-size: 0.9rem;
}

.login-footer a {
    font-weight: 600;
}
