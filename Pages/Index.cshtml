@page
@model MRMstudios.Pages.IndexModel
@{
    ViewData["Title"] = "Home";
}

<section class="hero-section">
    <div class="container">
        <div class="hero-inner">
            <div class="eyebrow">MRMstudios Photography</div>
            <h1 class="hero-title">Editorial images for real celebrations.</h1>
            <p class="hero-subtitle">Weddings, portraits, events, and business photography with calm direction and polished delivery.</p>
            <div class="hero-actions">
                <a href="/Booking" class="btn btn-primary">Book Your Session</a>
                <a href="/Packages" class="btn btn-secondary">View Packages</a>
            </div>
            <div class="hero-proof">
                <span>Wedding coverage</span>
                <span>Portrait sessions</span>
                <span>Corporate events</span>
            </div>
        </div>
    </div>
</section>

<section class="portfolio-section">
    <div class="container">
        <div class="section-heading">
            <div class="eyebrow">Portfolio</div>
            <h2>Recent work</h2>
            <p class="section-kicker">A focused selection of events, celebrations, and portrait sessions.</p>
        </div>

        <!-- Photo uploads managed by admin only -->

        <div class="gallery" id="gallery">
            <!-- Images will load here -->
        </div>
    </div>
</section>

<div id="lightbox" class="lightbox">
    <span class="close">&times;</span>
    <img class="lightbox-content" id="lightbox-img">
    <div class="caption" id="lightbox-caption"></div>
</div>

<section class="about-section">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <div class="eyebrow">About</div>
                <h2>Calm direction, clean editing, and images that feel like the day.</h2>
                <p>MRMstudios creates photography for clients who want natural moments, refined details, and a smooth experience from first message to final gallery.</p>
                <p>Every session is planned around your setting, pace, and priorities so the finished images feel personal and useful.</p>
                <div class="feature-list">
                    <span>Pre-session planning</span>
                    <span>High-resolution edited images</span>
                    <span>Digital gallery delivery</span>
                </div>
                <a href="/Packages" class="btn btn-primary">View Packages</a>
            </div>
            <div class="col-lg-6">
                <div class="about-image-grid">
                    <img src="/images/event.jpg" alt="Event photography reception">
                    <img src="/images/coporate.jpg" alt="Corporate photography session">
                </div>
            </div>
        </div>
    </div>
</section>

<section class="services-section">
    <div class="container">
        <div class="section-heading">
            <div class="eyebrow">Services</div>
            <h2>Photography packages</h2>
            <p class="section-kicker">Choose a starting point, then refine the details around your date, location, and vision.</p>
        </div>
        
        <div class="row g-4">
            <div class="col-md-6 col-lg-3 mb-4">
                <div class="service-card">
                    <img src="/images/coporate.jpg" class="service-image" alt="Professional portrait photography">
                    <h4>Portrait</h4>
                    <p>Professional headshots and family portraits</p>
                    <p class="price">$300</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3 mb-4">
                <div class="service-card">
                    <img src="/images/wedding.jpg" class="service-image" alt="Wedding photography">
                    <h4>Wedding</h4>
                    <p>Capturing your special day</p>
                    <p class="price">$800</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3 mb-4">
                <div class="service-card">
                    <img src="/images/event.jpg" class="service-image" alt="Event photography">
                    <h4>Event</h4>
                    <p>Corporate events and celebrations</p>
                    <p class="price">$600</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3 mb-4">
                <div class="service-card">
                    <img src="/images/coporate.jpg" class="service-image" alt="Business photography">
                    <h4>Corporate</h4>
                    <p>Business and professional photography</p>
                    <p class="price">$500</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="contact-section">
    <div class="container">
        <div class="contact-content">
            <div class="eyebrow">Start Here</div>
            <h2>Ready to plan your session?</h2>
            <p class="section-kicker">Share the date, the type of session, and what matters most. We will respond with next steps.</p>
            
            <div class="contact-grid">
                <div class="contact-pill">
                    <strong>Email</strong>
                    <p class="mb-0"><a href="mailto:mel.dimplz@gmail.com">mel.dimplz@gmail.com</a></p>
                </div>
                <div class="contact-pill">
                    <strong>Phone</strong>
                    <p class="mb-0"><a href="tel:+46708417437">+46 70 841 7437</a></p>
                </div>
            </div>

            <a href="/Booking" class="btn btn-primary">Book Now</a>
        </div>
    </div>
</section>

<script>
    const jsonUrl = '@Url.Content("~/images.json")';

    fetch(jsonUrl)
        .then(res => res.ok ? res.json() : [])
        .then(images => loadGallery(images))
        .catch(err => console.error("Error loading images:", err));

    function loadGallery(images) {
        const gallery = document.getElementById("gallery");
        gallery.innerHTML = "";
        if (!images || images.length === 0) {
            gallery.innerHTML = "<p style='grid-column: 1/-1; text-align: center;'>No images in the portfolio yet.</p>";
            return;
        }

        images.forEach(img => {
            const div = document.createElement("div");
            div.className = "gallery-item";
            div.innerHTML = `
                <img src="${img.src}" alt="${img.caption || 'Portfolio Image'}">
                <div class="caption">${img.caption || ''}</div>
            `;
            div.addEventListener("click", () => openLightbox(img.src, img.caption));
            gallery.appendChild(div);
        });
    }

    // Photo uploads are now managed from Admin page only

    // Lightbox functions
    const lightbox = document.getElementById("lightbox");
    const lightboxImg = document.getElementById("lightbox-img");
    const lightboxCaption = document.getElementById("lightbox-caption");
    const closeBtn = document.querySelector(".close");

    function openLightbox(src, caption) {
        lightbox.style.display = "flex";
        lightboxImg.src = src;
        lightboxCaption.textContent = caption || "";
    }

    closeBtn.onclick = () => (lightbox.style.display = "none");
    lightbox.onclick = (e) => {
        if (e.target === lightbox) lightbox.style.display = "none";
    };
</script>
