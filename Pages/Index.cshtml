@page
@model MRMstudios.Pages.IndexModel
@{
    ViewData["Title"] = "Home";
}

<!-- Hero Section -->
<section class="hero-section">
    <div class="container">
        <h1 class="hero-title">Professional Photography for Every Moment</h1>
        <p class="hero-subtitle">Weddings • Events • Portraits • Corporate</p>
        <a href="/Booking" class="btn btn-primary" style="margin-top: 2rem; padding: 0.9rem 2.5rem; font-size: 1.1rem;">Book Your Session</a>
    </div>
</section>

<!-- Portfolio Section -->
<section class="portfolio-section">
    <div class="container">
        <h2 style="text-align: center; margin-bottom: 1rem; font-size: 2rem; font-weight: 700;">My Portfolio</h2>
        <p style="text-align: center; color: #666; margin-bottom: 3rem; font-size: 1.1rem;">Explore recent work and sessions</p>

        <div class="upload-controls">
            <input type="file" id="fileInput" accept="image/*" multiple hidden>
            <button id="addPhotosBtn" class="btn btn-primary">+ Add Photos</button>
        </div>

        <div class="gallery" id="gallery">
            <!-- Images will load here -->
        </div>
    </div>
</section>

<!-- Lightbox Modal -->
<div id="lightbox" class="lightbox">
    <span class="close">&times;</span>
    <img class="lightbox-content" id="lightbox-img">
    <div class="caption" id="lightbox-caption"></div>
</div>

<!-- About Section -->
<section class="about-section">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <h2 style="font-size: 2rem; font-weight: 700; margin-bottom: 1.5rem;">About MRMstudios</h2>
                <p style="font-size: 1.05rem; line-height: 1.8; margin-bottom: 1rem;">
                    Welcome to MRMstudios! I'm a professional photographer specializing in weddings, events, and corporate shoots. Every image tells a story, evokes emotion, and preserves timeless beauty.
                </p>
                <p style="font-size: 1.05rem; line-height: 1.8; margin-bottom: 1.5rem;">
                    With years of experience and a passion for capturing authentic moments, I work with you to create stunning visual memories that you'll treasure forever.
                </p>
                <a href="/Packages" class="btn btn-primary">View Packages</a>
            </div>
            <div class="col-lg-6">
                <div style="background: linear-gradient(135deg, #f5f7fa 0%, #e7f3ff 100%); height: 400px; border-radius: 12px; display: flex; align-items: center; justify-content: center; color: #999;">
                    <span style="font-size: 4rem;">📸</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Services Preview Section -->
<section class="services-section">
    <div class="container">
        <h2 style="text-align: center; font-size: 2rem; font-weight: 700; margin-bottom: 1rem;">Services</h2>
        <p style="text-align: center; color: #666; margin-bottom: 3rem; font-size: 1.1rem;">Professional photography packages tailored to your needs</p>
        
        <div class="row">
            <div class="col-md-6 col-lg-3 mb-4">
                <div class="service-card">
                    <div class="service-icon">📷</div>
                    <h4>Portrait</h4>
                    <p>Professional headshots and family portraits</p>
                    <p class="price">$300</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3 mb-4">
                <div class="service-card">
                    <div class="service-icon">💒</div>
                    <h4>Wedding</h4>
                    <p>Capturing your special day</p>
                    <p class="price">$800</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3 mb-4">
                <div class="service-card">
                    <div class="service-icon">🎉</div>
                    <h4>Event</h4>
                    <p>Corporate events and celebrations</p>
                    <p class="price">$600</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3 mb-4">
                <div class="service-card">
                    <div class="service-icon">🏢</div>
                    <h4>Corporate</h4>
                    <p>Business and professional photography</p>
                    <p class="price">$500</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Contact Section -->
<section class="contact-section">
    <div class="container">
        <div class="contact-content">
            <h2 style="font-size: 2rem; font-weight: 700; margin-bottom: 1.5rem;">Ready to Capture Your Moments?</h2>
            <p style="font-size: 1.1rem; margin-bottom: 2rem; max-width: 600px; margin-left: auto; margin-right: auto;">
                Let's work together to create beautiful memories that last a lifetime.
            </p>
            
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; max-width: 600px; margin: 2rem auto; margin-bottom: 2rem;">
                <div>
                    <p style="margin-bottom: 0.5rem; font-weight: 600;">📧 Email</p>
                    <a href="mailto:mel.dimplz@gmail.com" style="color: var(--primary); font-size: 1rem;">mel.dimplz@gmail.com</a>
                </div>
                <div>
                    <p style="margin-bottom: 0.5rem; font-weight: 600;">📱 Phone</p>
                    <a href="tel:+46708417437" style="color: var(--primary); font-size: 1rem;">+46 70 841 7437</a>
                </div>
            </div>

            <a href="/Booking" class="btn btn-primary" style="padding: 0.9rem 2.5rem; font-size: 1.1rem;">Book Now</a>
        </div>
    </div>
</section>

<script>
    const jsonUrl = '@Url.Content("~/images.json")';

    fetch(jsonUrl)
        .then(res => res.ok ? res.json() : [])
        .then(images => loadGallery(images))
        .catch(err => console.error("Error loading images:", err));

    function loadGallery(images) {
        const gallery = document.getElementById("gallery");
        gallery.innerHTML = "";
        if (!images || images.length === 0) {
            gallery.innerHTML = "<p style='color:gray; grid-column: 1/-1; text-align: center;'>No images in the portfolio yet.</p>";
            return;
        }

        images.forEach(img => {
            const div = document.createElement("div");
            div.className = "gallery-item";
            div.innerHTML = `
                <img src="${img.src}" alt="${img.caption || 'Portfolio Image'}">
                <div class="caption">${img.caption || ''}</div>
            `;
            div.addEventListener("click", () => openLightbox(img.src, img.caption));
            gallery.appendChild(div);
        });
    }

    // Add photos from local device
    const addPhotosBtn = document.getElementById("addPhotosBtn");
    const fileInput = document.getElementById("fileInput");

    addPhotosBtn.addEventListener("click", () => fileInput.click());

    fileInput.addEventListener("change", (event) => {
        const files = event.target.files;
        if (!files.length) return;
        const gallery = document.getElementById("gallery");

        for (const file of files) {
            const reader = new FileReader();
            reader.onload = function (e) {
                const div = document.createElement("div");
                div.className = "gallery-item";
                div.innerHTML = `
                    <img src="${e.target.result}" alt="${file.name}">
                    <div class="caption">${file.name}</div>
                `;
                div.addEventListener("click", () => openLightbox(e.target.result, file.name));
                gallery.appendChild(div);
            };
            reader.readAsDataURL(file);
        }
    });

    // Lightbox functions
    const lightbox = document.getElementById("lightbox");
    const lightboxImg = document.getElementById("lightbox-img");
    const lightboxCaption = document.getElementById("lightbox-caption");
    const closeBtn = document.querySelector(".close");

    function openLightbox(src, caption) {
        lightbox.style.display = "flex";
        lightboxImg.src = src;
        lightboxCaption.textContent = caption || "";
    }

    closeBtn.onclick = () => (lightbox.style.display = "none");
    lightbox.onclick = (e) => {
        if (e.target === lightbox) lightbox.style.display = "none";
    };
</script>
