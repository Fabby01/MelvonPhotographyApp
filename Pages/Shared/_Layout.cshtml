<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <title>@ViewData["Title"] - MRMstudios</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MRMstudios.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index" style="font-weight: 700; font-size: 1.3rem;">🎨 MRMstudios</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Index">🏠 Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Packages">💰 Packages</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Booking">📅 Book Now</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Contact">📞 Contact</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/AdminBookings">⚙️ Admin</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Privacy">Privacy</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    
    <main role="main">
        @RenderBody()
    </main>

    <footer class="footer mt-5">
        <div class="container">
            <div class="row py-4">
                <div class="col-12 col-md-6 mb-3 mb-md-0">
                    <strong style="font-size: 1.1rem; display: block; margin-bottom: 0.5rem;">MRMstudios</strong>
                    <p style="margin: 0.5rem 0;">Professional Photography Services</p>
                    <p style="margin: 0.5rem 0; font-size: 0.9rem;"><a asp-area="" asp-page="/Contact">Contact</a> | <a asp-area="" asp-page="/Privacy">Privacy</a></p>
                </div>
                <div class="col-12 col-md-6">
                    <strong style="font-size: 1.1rem; display: block; margin-bottom: 0.5rem;">Get in Touch</strong>
                    <p style="margin: 0.5rem 0;">📧 <a href="mailto:mel.dimplz@gmail.com">mel.dimplz@gmail.com</a></p>
                    <p style="margin: 0.5rem 0;">📱 <a href="tel:+46708417437">+46 70 841 7437</a></p>
                </div>
            </div>
            <div style="border-top: 1px solid rgba(255, 255, 255, 0.1); padding-top: 1.5rem; text-align: center; font-size: 0.9rem; opacity: 0.8;">
                &copy; 2026 MRMstudios. All rights reserved.
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>